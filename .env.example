# Copy to .env and change every value before running.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=app

# Login role PostgREST uses. Must match what 00-roles.sh sets. Alphanumeric only.
AUTHENTICATOR_PASSWORD=change-me-authenticator

# HMAC secret PostgREST uses to verify JWTs. Use a long random string (>= 32 chars).
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-characters
