{{if .Name}}name: {{.Name}}
{{end}}services:
  {{.DBService}}:
    build: .
    image: {{.Image}}
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB}
{{- if .API}}
      AUTHENTICATOR_PASSWORD: ${AUTHENTICATOR_PASSWORD}
{{- end}}
    ports:
      - "{{.Bind}}{{.DBPort}}:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $${POSTGRES_USER} -d $${POSTGRES_DB}"]
      interval: 5s
      timeout: 5s
      retries: 12
{{- if .API}}
  {{.PostgRESTService}}:
    image: {{.PostgRESTImage}}
    restart: unless-stopped
    environment:
      PGRST_DB_URI: postgres://authenticator:${AUTHENTICATOR_PASSWORD}@{{.DBService}}:5432/${POSTGRES_DB}
      PGRST_DB_SCHEMAS: public
      PGRST_DB_ANON_ROLE: anon
      PGRST_JWT_SECRET: ${JWT_SECRET}
{{- if .JWTAud}}
      PGRST_JWT_AUD: {{.JWTAud}}
{{- end}}
    ports:
      - "{{.Bind}}{{.PostgRESTPort}}:3000"
    depends_on:
      {{.DBService}}:
        condition: service_healthy
{{- end}}
volumes:
  pgdata:
